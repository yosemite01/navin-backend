{
  "name": "navin-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "seed": "tsx src/scripts/seed.ts",
    "generate-api-key": "tsx src/scripts/generateApiKey.ts",
    "worker:stellar": "tsx src/workers/stellar.worker.ts",
    "migrate:up": "migrate-mongo up --config migrate-mongo.config.cjs",
    "migrate:down": "migrate-mongo down --config migrate-mongo.config.cjs",
    "migrate:status": "migrate-mongo status --config migrate-mongo.config.cjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@stellar/stellar-sdk": "^14.5.0",
    "@types/helmet": "^0.0.48",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.58.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "migrate-mongo": "^11.0.0",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pino": "^9.14.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.19",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.6",
    "mongodb-memory-server": "^10.2.0",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix"
    ]
  }
}
